# ── Dispatch ───────────────────────────────────────────

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    setup)      cmd_setup "$@" ;;
    tutorial)   cmd_tutorial "$@" ;;
    doctor)     cmd_doctor ;;
    init)       cmd_init "$@" ;;
    check)      cmd_check "$@" ;;
    gate)
        if [ -z "${1:-}" ]; then
            printf "${RED}Usage: paw gate <agent-name>${RESET}\n"
            printf "  Run ${CYAN}paw agents${RESET} to see available agents.\n"
            exit 1
        fi
        cmd_gate "$1"
        ;;
    agents)     cmd_agents ;;
    next)       cmd_next ;;
    suggest)    cmd_suggest "$@" ;;
    cheatsheet) cmd_cheatsheet ;;
    desktop)    cmd_desktop ;;
    uninstall)  cmd_uninstall ;;
    completions) cmd_completions "${1:-zsh}" ;;
    version|-v|--version)  cmd_version ;;
    help|-h|--help)        show_help ;;
    *)
        printf "${RED}Unknown command: %s${RESET}\n\n" "$cmd"
        show_help
        exit 1
        ;;
esac
