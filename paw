#!/usr/bin/env bash
# paw — AI SDLC starter kit CLI
# Usage: paw <command> [args]

set -euo pipefail

PAW_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Colors ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Help ───────────────────────────────────────────────

show_help() {
    printf "${CYAN}${BOLD}paw${RESET} — Personal Agent Workflows — an AI SDLC starter kit\n\n"
    printf "${BOLD}Usage:${RESET} paw <command> [args]\n\n"
    printf "${BOLD}Commands:${RESET}\n"
    printf "  ${CYAN}setup${RESET}          Check requirements and install hooks\n"
    printf "  ${CYAN}tutorial${RESET}       Run the interactive TUI walkthrough\n"
    printf "  ${CYAN}doctor${RESET}         Diagnose problems with your paw install\n"
    printf "  ${CYAN}init${RESET}           Scaffold .paw.json config into a project\n"
    printf "  ${CYAN}check${RESET}          Run standard quality gate (3 reviewers)\n"
    printf "  ${CYAN}gate${RESET} <name>    Run a single review agent\n"
    printf "  ${CYAN}agents${RESET}         List all available agents\n"
    printf "  ${CYAN}next${RESET}           Suggested next steps based on your progress\n"
    printf "  ${CYAN}suggest${RESET}        Detect your stack and recommend agents\n"
    printf "  ${CYAN}cheatsheet${RESET}     Print the quick reference card\n"
    printf "  ${CYAN}desktop${RESET}        Create a Desktop app launcher (macOS)\n"
    printf "  ${CYAN}uninstall${RESET}      Remove hooks and symlink\n"
    printf "  ${CYAN}completions${RESET}    Output shell completions (zsh|bash)\n"
    printf "  ${CYAN}version${RESET}        Show paw version\n"
    printf "  ${CYAN}help${RESET}           Show this help\n"
    printf "\n${BOLD}Quality gate presets:${RESET}\n"
    printf "  ${CYAN}paw check${RESET}              Standard (code + bugs + security)\n"
    printf "  ${CYAN}paw check --quick${RESET}      Quick (code-reviewer only)\n"
    printf "  ${CYAN}paw check --thorough${RESET}   Thorough (all 8 reviewers)\n"
    printf "\n${BOLD}Single agent:${RESET}\n"
    printf "  ${CYAN}paw gate security${RESET}      Run security-reviewer\n"
    printf "  ${CYAN}paw gate bugs${RESET}          Run bug-auditor\n"
    printf "  ${CYAN}paw gate perf${RESET}          Run perf-checker\n"
    printf "  ${CYAN}paw gate frontend${RESET}      Run fe-reviewer\n"
    printf "  ${CYAN}paw gate php${RESET}           Run php-reviewer\n"
    printf "\n${DIM}paw v$(cat "$PAW_DIR/pyproject.toml" | grep 'version' | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')${RESET}\n"
}

# ── Commands ───────────────────────────────────────────

cmd_setup() {
    exec "$PAW_DIR/setup" "$@"
}

cmd_tutorial() {
    for arg in "$@"; do
        if [ "$arg" = "--web" ]; then
            printf "${CYAN}Opening browser tutorial...${RESET}\n"
            open "$PAW_DIR/tutorial.html" 2>/dev/null \
                || xdg-open "$PAW_DIR/tutorial.html" 2>/dev/null \
                || printf "Open ${PAW_DIR}/tutorial.html in your browser.\n"
            return
        fi
    done
    exec python3 "$PAW_DIR/tutorial" "$@"
}

cmd_version() {
    ver=$(grep 'version' "$PAW_DIR/pyproject.toml" | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
    printf "paw v%s\n" "$ver"
    printf "${DIM}%s${RESET}\n" "$PAW_DIR"
}

cmd_agents() {
    printf "${CYAN}${BOLD}paw agents${RESET} — 18 specialized agents\n\n"
    printf "${BOLD}%-22s %-12s %s${RESET}\n" "AGENT" "PHASE" "PERMISSION"
    printf "%-22s %-12s %s\n" "──────────────────────" "────────────" "──────────────"
    printf "%-22s %-12s %s\n" "architect"              "plan"         "read-only"
    printf "%-22s %-12s %s\n" "planner"                "plan"         "read-only"
    printf "%-22s %-12s %s\n" "devils-advocate"        "plan"         "read-only"
    printf "%-22s %-12s %s\n" "rollback-planner"       "plan"         "read-only"
    printf "%-22s %-12s %s\n" "builder"                "build"        "full"
    printf "%-22s %-12s %s\n" "merge-resolver"         "build"        "full"
    printf "%-22s %-12s %s\n" "migration-architect"    "build"        "full"
    printf "%-22s %-12s %s\n" "code-reviewer"          "review"       "read-only"
    printf "%-22s %-12s %s\n" "bug-auditor"            "review"       "read-only"
    printf "%-22s %-12s %s\n" "security-reviewer"      "review"       "read-only"
    printf "%-22s %-12s %s\n" "perf-checker"           "review"       "read-only"
    printf "%-22s %-12s %s\n" "fe-reviewer"            "review"       "read-only"
    printf "%-22s %-12s %s\n" "php-reviewer"           "review"       "read-only"
    printf "%-22s %-12s %s\n" "test-runner"            "review"       "read+bash"
    printf "%-22s %-12s %s\n" "integration-tester"     "review"       "read+bash"
    printf "%-22s %-12s %s\n" "environment-checker"    "review"       "read+bash"
    printf "%-22s %-12s %s\n" "incident-commander"     "respond"      "full"
    printf "%-22s %-12s %s\n" "docs-writer"            "document"     "read+write"
}

cmd_gate() {
    local agent="$1"
    case "$agent" in
        security)  agent="security-reviewer" ;;
        bugs)      agent="bug-auditor" ;;
        code)      agent="code-reviewer" ;;
        perf)      agent="perf-checker" ;;
        frontend)  agent="fe-reviewer" ;;
        php)       agent="php-reviewer" ;;
        tests)     agent="test-runner" ;;
        docs)      agent="docs-writer" ;;
        env)       agent="environment-checker" ;;
    esac
    printf "${CYAN}Running:${RESET} %s\n\n" "$agent"
    printf "Paste this into Claude Code, Cursor, or Codex CLI:\n\n"
    printf "  ${BOLD}Use the %s agent on the current diff.${RESET}\n\n" "$agent"
    printf "${DIM}Agent definition: %s/agents/%s.md${RESET}\n" "$PAW_DIR" "$agent"
}

cmd_check() {
    local preset="standard"
    for arg in "$@"; do
        case "$arg" in
            --quick)    preset="quick" ;;
            --thorough) preset="thorough" ;;
        esac
    done

    printf "${CYAN}${BOLD}paw check${RESET} — %s quality gate\n\n" "$preset"

    case "$preset" in
        quick)
            printf "Paste this into Claude Code, Cursor, or Codex CLI:\n\n"
            printf "  ${BOLD}Use the code-reviewer agent on the current diff.${RESET}\n"
            ;;
        standard)
            printf "Paste this into Claude Code, Cursor, or Codex CLI:\n\n"
            printf "  ${BOLD}Use the code-reviewer agent, then the bug-auditor\n"
            printf "  agent, then the security-reviewer agent on the\n"
            printf "  current diff.${RESET}\n"
            ;;
        thorough)
            printf "Paste this into Claude Code, Cursor, or Codex CLI:\n\n"
            printf "  ${BOLD}Use the code-reviewer, bug-auditor, security-reviewer,\n"
            printf "  perf-checker, fe-reviewer, php-reviewer, test-runner,\n"
            printf "  and docs-writer agents on the current diff.${RESET}\n"
            ;;
    esac

    printf "\n${DIM}Preset definitions: %s/skills/quality-gate/SKILL.md${RESET}\n" "$PAW_DIR"
}

cmd_init() {
    local target="${1:-.}"
    local config_file="$target/.paw.json"

    if [ ! -d "$target" ]; then
        printf "${RED}Directory not found: %s${RESET}\n" "$target"
        return 1
    fi

    if [ -f "$config_file" ]; then
        printf "${YELLOW}%s already exists.${RESET}\n" "$config_file"
        printf "Edit it directly, or delete it to re-init.\n"
        return 1
    fi

    cat > "$config_file" << 'INITEOF'
{
  "paw_version": "0.2.0",
  "description": "paw config — customize which agents, rules, and gates apply to this project.",

  "agents": {
    "enabled": [
      "architect",
      "planner",
      "devils-advocate",
      "code-reviewer",
      "bug-auditor",
      "security-reviewer",
      "builder",
      "test-runner",
      "perf-checker",
      "docs-writer"
    ],
    "disabled": [
      "fe-reviewer",
      "php-reviewer",
      "merge-resolver",
      "migration-architect",
      "incident-commander",
      "rollback-planner",
      "integration-tester",
      "environment-checker"
    ]
  },

  "rules": {
    "enabled": [
      "git-doctrine",
      "test-first",
      "error-handling",
      "no-secrets-in-code",
      "branch-hygiene",
      "security-basics"
    ]
  },

  "quality_gate": {
    "default_preset": "standard",
    "presets": {
      "quick": ["code-reviewer"],
      "standard": ["code-reviewer", "bug-auditor", "security-reviewer"],
      "thorough": [
        "code-reviewer", "bug-auditor", "security-reviewer",
        "perf-checker", "test-runner", "docs-writer"
      ]
    }
  },

  "history": {
    "enabled": false,
    "path": ".paw/history.jsonl"
  }
}
INITEOF

    printf "${GREEN}✓${RESET} Created %s\n\n" "$config_file"
    printf "  Edit ${BOLD}agents.enabled${RESET} to choose which agents run.\n"
    printf "  Edit ${BOLD}agents.disabled${RESET} to skip irrelevant ones.\n"
    printf "  Edit ${BOLD}quality_gate.default_preset${RESET} for your team's default.\n"
    printf "\n  ${DIM}Add .paw.json to version control so your team shares the config.${RESET}\n"
}

cmd_doctor() {
    printf "${CYAN}${BOLD}paw doctor${RESET} — checking your install\n\n"
    local issues=0

    # Check Python
    if command -v python3 &>/dev/null; then
        printf "  ${GREEN}✓${RESET} Python3 found\n"
    else
        printf "  ${RED}✗${RESET} Python3 not found\n"
        issues=$((issues + 1))
    fi

    # Check curses
    if python3 -c "import curses" 2>/dev/null; then
        printf "  ${GREEN}✓${RESET} curses module available\n"
    else
        printf "  ${RED}✗${RESET} curses module missing\n"
        issues=$((issues + 1))
    fi

    # Check hook files exist
    for hook in git_safety.py branch_guard.py auto_test_detect.sh _lib.py; do
        if [ -f "$PAW_DIR/hooks/$hook" ]; then
            printf "  ${GREEN}✓${RESET} hooks/%s exists\n" "$hook"
        else
            printf "  ${RED}✗${RESET} hooks/%s missing\n" "$hook"
            issues=$((issues + 1))
        fi
    done

    # Check hooks are executable
    for hook in git_safety.py branch_guard.py auto_test_detect.sh; do
        if [ -x "$PAW_DIR/hooks/$hook" ]; then
            printf "  ${GREEN}✓${RESET} hooks/%s executable\n" "$hook"
        else
            printf "  ${YELLOW}!${RESET} hooks/%s not executable — fixing\n" "$hook"
            chmod +x "$PAW_DIR/hooks/$hook"
        fi
    done

    # Check settings.json has paw hooks
    local settings="$HOME/.claude/settings.json"
    if [ -f "$settings" ]; then
        if grep -q "git_safety.py" "$settings" 2>/dev/null; then
            printf "  ${GREEN}✓${RESET} git_safety hook installed in settings.json\n"
        else
            printf "  ${YELLOW}!${RESET} git_safety hook not in settings.json\n"
            printf "    ${DIM}Run: paw setup${RESET}\n"
            issues=$((issues + 1))
        fi
        if grep -q "branch_guard.py" "$settings" 2>/dev/null; then
            printf "  ${GREEN}✓${RESET} branch_guard hook installed in settings.json\n"
        else
            printf "  ${YELLOW}!${RESET} branch_guard hook not in settings.json\n"
            issues=$((issues + 1))
        fi
    else
        printf "  ${YELLOW}!${RESET} ~/.claude/settings.json not found\n"
        printf "    ${DIM}Is Claude Code installed?${RESET}\n"
        issues=$((issues + 1))
    fi

    # Check agent files
    local agent_count
    agent_count=$(find "$PAW_DIR/agents" -name "*.md" -not -name "README.md" | wc -l | tr -d ' ')
    if [ "$agent_count" -eq 18 ]; then
        printf "  ${GREEN}✓${RESET} All 18 agent definitions present\n"
    else
        printf "  ${YELLOW}!${RESET} Found %s agent files (expected 18)\n" "$agent_count"
        issues=$((issues + 1))
    fi

    # Check hook self-test
    local test_result
    test_result=$(echo '{"tool_input":{"command":"git rebase main"}}' | python3 "$PAW_DIR/hooks/git_safety.py" 2>&1 || true)
    if echo "$test_result" | grep -q "block"; then
        printf "  ${GREEN}✓${RESET} git_safety.py blocks rebase (verified)\n"
    else
        printf "  ${RED}✗${RESET} git_safety.py did not block rebase\n"
        issues=$((issues + 1))
    fi

    # Check tests pass
    if command -v pytest &>/dev/null || python3 -m pytest --version &>/dev/null 2>&1; then
        if python3 -m pytest "$PAW_DIR/tests/" -q --tb=no 2>/dev/null | grep -q "passed"; then
            local passed
            passed=$(python3 -m pytest "$PAW_DIR/tests/" -q --tb=no 2>/dev/null | grep -oE '[0-9]+ passed')
            printf "  ${GREEN}✓${RESET} Tests: %s\n" "$passed"
        else
            printf "  ${YELLOW}!${RESET} Some tests failing\n"
            printf "    ${DIM}Run: python3 -m pytest %s/tests/ -v${RESET}\n" "$PAW_DIR"
            issues=$((issues + 1))
        fi
    else
        printf "  ${DIM}-${RESET} pytest not installed (optional)\n"
    fi

    printf "\n"
    if [ "$issues" -eq 0 ]; then
        printf "  ${GREEN}${BOLD}No issues found.${RESET} paw is healthy.\n"
    else
        printf "  ${YELLOW}${BOLD}%d issue(s) found.${RESET}\n" "$issues"
        printf "  ${DIM}Run: paw setup${RESET}\n"
    fi
    printf "\n"
}

# ── Desktop launcher ───────────────────────────────────

cmd_desktop() {
    local app_path="$HOME/Desktop/paw.app"
    local contents="$app_path/Contents"
    local macos="$contents/MacOS"

    if [ -d "$app_path" ]; then
        printf "${YELLOW}%s already exists.${RESET}\n" "$app_path"
        printf "Delete it first to recreate: rm -rf '%s'\n" "$app_path"
        return 1
    fi

    mkdir -p "$macos"

    # Info.plist
    cat > "$contents/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>paw</string>
    <key>CFBundleDisplayName</key>
    <string>paw tutorial</string>
    <key>CFBundleIdentifier</key>
    <string>com.paw.tutorial</string>
    <key>CFBundleVersion</key>
    <string>0.3.0</string>
    <key>CFBundleExecutable</key>
    <string>launch</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
</dict>
</plist>
PLIST

    # Launch script
    cat > "$macos/launch" << LAUNCHER
#!/usr/bin/env bash
PAW_DIR="$PAW_DIR"
PORT=8042

# Kill existing server on this port
lsof -ti :"\$PORT" 2>/dev/null | xargs kill 2>/dev/null || true

# First-run setup if hooks not installed
SETTINGS="\$HOME/.claude/settings.json"
if [ ! -f "\$SETTINGS" ] || ! grep -q "git_safety.py" "\$SETTINGS" 2>/dev/null; then
    osascript -e 'display dialog "paw needs to install git safety hooks to your Claude Code settings. This is a one-time setup." buttons {"Cancel", "Install"} default button "Install" with title "paw setup"' 2>/dev/null
    if [ \$? -eq 0 ]; then
        "\$PAW_DIR/paw" setup --yes
    fi
fi

# Start server and open browser
python3 -m http.server "\$PORT" --directory "\$PAW_DIR" &>/dev/null &
sleep 1
open "http://localhost:\${PORT}/tutorial.html"
LAUNCHER
    chmod +x "$macos/launch"

    printf "${GREEN}✓${RESET} Created ${BOLD}%s${RESET}\n\n" "$app_path"
    printf "  Double-click it on your Desktop to launch the\n"
    printf "  paw tutorial in your browser.\n\n"
    printf "  ${DIM}First launch will ask to install hooks.${RESET}\n"
    printf "  ${DIM}After that, it just opens the tutorial.${RESET}\n\n"
}

# ── Uninstall ──────────────────────────────────────────

cmd_uninstall() {
    printf "${CYAN}${BOLD}paw uninstall${RESET}\n\n"

    local settings="$HOME/.claude/settings.json"
    if [ -f "$settings" ] && command -v python3 &>/dev/null; then
        python3 -c "
import json, sys
path = '$settings'
with open(path) as f:
    s = json.load(f)
hooks = s.get('hooks', {})
changed = False
for event in ['PreToolUse', 'PostToolUse']:
    entries = hooks.get(event, [])
    filtered = [e for e in entries if not any('paw' in h.get('command','') for h in e.get('hooks',[]))]
    if len(filtered) != len(entries):
        hooks[event] = filtered
        changed = True
if changed:
    with open(path, 'w') as f:
        json.dump(s, f, indent=2)
        f.write('\n')
    print('  Removed paw hooks from settings.json.')
else:
    print('  No paw hooks found in settings.json.')
"
    fi

    local link="$HOME/.local/bin/paw"
    if [ -L "$link" ]; then
        rm "$link"
        printf "  Removed symlink: %s\n" "$link"
    fi

    printf "\n  ${DIM}paw files remain at %s${RESET}\n" "$PAW_DIR"
    printf "  ${DIM}Delete manually: rm -rf %s${RESET}\n\n" "$PAW_DIR"
}

# ── Shell completion ───────────────────────────────────

cmd_completions() {
    local shell="${1:-zsh}"
    case "$shell" in
        zsh)
            cat << 'COMP'
#compdef paw
_paw() {
    local -a commands
    commands=(
        'setup:Check requirements and install hooks'
        'tutorial:Run the interactive tutorial'
        'doctor:Diagnose problems with your install'
        'init:Scaffold .paw.json config'
        'check:Run quality gate'
        'gate:Run a single review agent'
        'agents:List all agents'
        'uninstall:Remove hooks and symlink'
        'completions:Output shell completions'
        'version:Show version'
        'help:Show help'
    )
    local -a gates
    gates=(security bugs code perf frontend php tests docs env)
    if (( CURRENT == 2 )); then
        _describe 'command' commands
    elif (( CURRENT == 3 )) && [[ "$words[2]" == "gate" ]]; then
        _describe 'agent' gates
    fi
}
compdef _paw paw
COMP
            ;;
        bash)
            cat << 'COMP'
_paw() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local prev="${COMP_WORDS[COMP_CWORD-1]}"
    local cmds="setup tutorial doctor init check gate agents uninstall completions version help"
    local gates="security bugs code perf frontend php tests docs env"
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=($(compgen -W "$cmds" -- "$cur"))
    elif [ "$prev" = "gate" ]; then
        COMPREPLY=($(compgen -W "$gates" -- "$cur"))
    fi
}
complete -F _paw paw
COMP
            ;;
    esac
}

# ── Next steps ─────────────────────────────────────────

cmd_next() {
    printf "${CYAN}${BOLD}paw next${RESET} — suggested next steps\n\n"
    local done=0
    local total=7

    # 1. Hooks installed?
    local settings="$HOME/.claude/settings.json"
    if [ -f "$settings" ] && grep -q "git_safety.py" "$settings" 2>/dev/null; then
        printf "  ${GREEN}✓${RESET} Hooks installed\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Install hooks:${RESET} paw setup\n"
        printf "    ${DIM}Git guardrails that block rebase, force-push, commits to main.${RESET}\n\n"
        return
    fi

    # 2. Global command?
    if command -v paw &>/dev/null && [ "$(command -v paw)" != "$PAW_DIR/paw" ]; then
        printf "  ${GREEN}✓${RESET} paw on PATH\n"
        done=$((done + 1))
    elif [ -L "$HOME/.local/bin/paw" ]; then
        printf "  ${GREEN}✓${RESET} paw on PATH\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Add paw to PATH:${RESET} paw setup\n"
        printf "    ${DIM}Run paw from any directory.${RESET}\n\n"
    fi

    # 3. Tried a review agent?
    local history_marker="$PAW_DIR/.paw_used_agent"
    if [ -f "$history_marker" ]; then
        printf "  ${GREEN}✓${RESET} Ran a review agent\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Run a review agent:${RESET} paw check --quick\n"
        printf "    ${DIM}See what the code-reviewer finds on your current diff.${RESET}\n\n"
    fi

    # 4. Project config?
    if [ -f ".paw.json" ]; then
        printf "  ${GREEN}✓${RESET} Project config (.paw.json)\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Configure for your project:${RESET} paw init\n"
        printf "    ${DIM}Customize agents and presets for your team.${RESET}\n\n"
    fi

    # 5. Tried buggy app?
    local buggy_marker="$PAW_DIR/.paw_tried_buggy"
    if [ -f "$buggy_marker" ]; then
        printf "  ${GREEN}✓${RESET} Tried the buggy app\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Practice:${RESET} paw gate security  ${DIM}(on examples/buggy-app/)${RESET}\n"
        printf "    ${DIM}6 security holes, 4 bugs, 0 tests. How many can agents find?${RESET}\n\n"
    fi

    # 6. Stacked reviewers?
    local stack_marker="$PAW_DIR/.paw_stacked"
    if [ -f "$stack_marker" ]; then
        printf "  ${GREEN}✓${RESET} Stacked multiple reviewers\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Stack 3 reviewers:${RESET} paw check\n"
        printf "    ${DIM}code-reviewer + bug-auditor + security-reviewer.${RESET}\n\n"
    fi

    # 7. Full workflow?
    local workflow_marker="$PAW_DIR/.paw_workflow"
    if [ -f "$workflow_marker" ]; then
        printf "  ${GREEN}✓${RESET} Ran the full workflow\n"
        done=$((done + 1))
    else
        printf "  ${CYAN}→${RESET} ${BOLD}Full workflow:${RESET} architect → planner → devils-advocate → builder → code-reviewer\n"
        printf "    ${DIM}The complete plan-critique-build-review cycle.${RESET}\n\n"
    fi

    printf "\n  ${DIM}Progress: %d/%d${RESET}\n\n" "$done" "$total"
}

# ── Suggest ────────────────────────────────────────────

cmd_suggest() {
    printf "${CYAN}${BOLD}paw suggest${RESET} — agents for this project\n\n"

    local dir="${1:-.}"
    local agents_on=""
    local agents_off=""

    # Detect stack
    if [ -f "$dir/package.json" ]; then
        printf "  ${GREEN}Detected:${RESET} Node.js / JavaScript project\n"
        if grep -q "react\|next\|vue\|angular\|svelte" "$dir/package.json" 2>/dev/null; then
            printf "  ${GREEN}Detected:${RESET} Frontend framework\n"
            agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker fe-reviewer test-runner builder docs-writer"
            agents_off="php-reviewer migration-architect"
        else
            agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker test-runner builder docs-writer"
            agents_off="php-reviewer fe-reviewer migration-architect"
        fi
    elif [ -f "$dir/composer.json" ]; then
        printf "  ${GREEN}Detected:${RESET} PHP project\n"
        if grep -q "laravel" "$dir/composer.json" 2>/dev/null; then
            printf "  ${GREEN}Detected:${RESET} Laravel framework\n"
        fi
        agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker php-reviewer test-runner builder migration-architect docs-writer"
        agents_off="fe-reviewer"
    elif [ -f "$dir/pyproject.toml" ] || [ -f "$dir/setup.py" ] || [ -f "$dir/requirements.txt" ]; then
        printf "  ${GREEN}Detected:${RESET} Python project\n"
        agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker test-runner builder docs-writer"
        agents_off="php-reviewer fe-reviewer"
    elif [ -f "$dir/go.mod" ]; then
        printf "  ${GREEN}Detected:${RESET} Go project\n"
        agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker test-runner builder docs-writer"
        agents_off="php-reviewer fe-reviewer"
    elif [ -f "$dir/Cargo.toml" ]; then
        printf "  ${GREEN}Detected:${RESET} Rust project\n"
        agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker test-runner builder docs-writer"
        agents_off="php-reviewer fe-reviewer"
    else
        printf "  ${YELLOW}Could not detect project type.${RESET}\n"
        printf "  ${DIM}Showing all agents. Run from your project root.${RESET}\n\n"
        agents_on="architect planner devils-advocate code-reviewer bug-auditor security-reviewer perf-checker test-runner builder docs-writer"
        agents_off="php-reviewer fe-reviewer"
    fi

    # Check for database files
    if [ -f "$dir/migrations" ] || ls "$dir"/**/migrations/ &>/dev/null 2>&1 || grep -rq "migration\|alembic\|knex\|prisma" "$dir" --include="*.json" --include="*.toml" 2>/dev/null; then
        printf "  ${GREEN}Detected:${RESET} Database migrations\n"
        agents_on="$agents_on migration-architect rollback-planner"
    fi

    printf "\n  ${BOLD}Recommended agents:${RESET}\n"
    for a in $agents_on; do
        printf "    ${GREEN}✓${RESET} %s\n" "$a"
    done

    if [ -n "$agents_off" ]; then
        printf "\n  ${BOLD}Skip for this project:${RESET}\n"
        for a in $agents_off; do
            printf "    ${DIM}✗ %s${RESET}\n" "$a"
        done
    fi

    printf "\n  ${DIM}Run: paw init${RESET}  ${DIM}to save this config to .paw.json${RESET}\n\n"
}

